{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    },
    "figma": {
      "command": "npx",
      "args": ["figma-developer-mcp"],
      "env": {
        "FIGMA_CLIENT_ID": "${FIGMA_CLIENT_ID}",
        "FIGMA_CLIENT_SECRET": "${FIGMA_CLIENT_SECRET}"
      }
    }
  }
}
