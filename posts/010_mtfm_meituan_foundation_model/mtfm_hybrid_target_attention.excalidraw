      "updated": 1234567890,
      "link": null,
      "locked": false,
      "text": "标准注意力\n(Standard Attention)\n\nAtt(Q,K,V) = softmax(QK^T/√d)V\n\n所有 Token 都相互关注",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 12
    },
