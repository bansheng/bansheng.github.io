      "updated": 1234567890,
      "link": null,
      "locked": false,
      "text": "MTFM: 混合目标注意力机制 (Hybrid Target Attention)",
      "fontSize": 26,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 26
    },
    {
      "type": "text",
      "version": 1,
