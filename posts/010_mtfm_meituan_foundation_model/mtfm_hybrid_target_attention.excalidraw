      "boundElements": null,
      "updated": 1234567890,
      "link": null,
      "locked": false,
      "text": "目标驱动注意力\n(Target-driven Attention)\n\n仅H/R关注所有Token\nT-tokens 只被关注，不关注他人",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 12
    },
