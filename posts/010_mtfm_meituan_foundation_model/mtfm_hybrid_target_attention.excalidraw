      "locked": false,
      "text": "混合注意力\n(Hybrid Target Attention)\n\n结合两种策略\n灵活适应多场景",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 12
